# Live Smoke Test — environment template
# Copy to `.env` next to smoke.py and fill in real values. Never commit `.env`.
#
# Required for both --env test and --env live runs.

# Site origin under test (no trailing slash)
LIVE_URL=https://example.lovable.app

# Postgres connection string for the target environment
LIVE_DATABASE_URL=postgresql://user:password@host:5432/postgres

# Admin login used by the UI sweep
LIVE_ADMIN_EMAIL=admin@example.com
LIVE_ADMIN_PASSWORD=replace-me

# Supabase project URL + anon key (used to mint a session for the headless browser)
LIVE_SUPABASE_URL=https://your-project.supabase.co
LIVE_SUPABASE_ANON_KEY=replace-with-anon-key

# Production safety flag — REQUIRED when running with `--env live`.
# Must be exactly: I_UNDERSTAND_THIS_TOUCHES_PRODUCTION
# Leave blank or unset for `--env test`.
LIVE_CONFIRM=

# Optional build identifier (auto-detected via `git rev-parse` if unset).
# Useful in CI runners that already expose COMMIT_SHA / GITHUB_SHA.
# COMMIT_SHA=
