# Frontend (Vite / Vercel)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-ref
# Preferred client key name. Use the current sb_publishable_* key from Supabase/Lovable.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# Compatibility alias for older tooling that still expects the anon key name.
VITE_SUPABASE_ANON_KEY=
# Google Analytics alias supported by src/lib/analytics.ts.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GOOGLE_ANALYTICS_ID=
# Optional diagnostics overrides used by HQ tooling.
VITE_DIAGNOSTICS_EXPECTED_URL=https://your-project.supabase.co
VITE_DIAGNOSTICS_EXPECTED_PROJECT_ID=your-project-ref
# Optional Google client-side integrations (only if wired into the frontend).
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Supabase Edge Functions / backend runtime
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
RESEND_API_KEY=re_your_key_here
STRIPE_SECRET_KEY=sk_live_or_test_key_here
LOVABLE_API_KEY=your-lovable-api-key
GOOGLE_MAIL_API_KEY=your-google-mail-api-key
INTERNAL_FUNCTION_SECRET=shared-internal-function-secret

# Verified sender identities (Resend)
FROM_EMAIL=notify@notify.peninsulaequine.systems
HQ_EMAIL_FROM=hq@notify.peninsulaequine.systems
BOOKINGS_EMAIL_FROM=bookings@notify.peninsulaequine.systems
QUOTES_EMAIL_FROM=quotes@notify.peninsulaequine.systems
NOREPLY_EMAIL_FROM=noreply@notify.peninsulaequine.systems
NOTIFICATION_EMAIL=info@peninsulaequine.systems

# Optional legacy auth bridge
LEGACY_API_URL=
LEGACY_API_KEY=

# Publish / diagnostics tooling
SB_MGMT_ACCESS_TOKEN=your-supabase-management-token
SUPABASE_PROJECT_REF=your-project-ref
PUBLISH_LOG_INGEST_URL=
PUBLISH_LOG_INGEST_SECRET=

# Optional external security connector
WIZ_API_URL=
WIZ_CLIENT_ID=
WIZ_CLIENT_SECRET=
WIZ_AUTH_URL=https://auth.app.wiz.io/oauth/token
WIZ_PROJECT_ID=

# Optional E2E / smoke-test credentials (never commit real values)
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
E2E_VERIFY_SECRET=
E2E_BASE_URL=https://peninsulaequine.systems

# Vercel
# VERCEL_URL is injected automatically by Vercel at deploy time.
