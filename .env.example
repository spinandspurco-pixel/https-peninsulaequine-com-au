# ============================================================
# Peninsula Equine — Environment Variables Reference
# ============================================================
# Copy this file to .env (never commit .env) and fill in real values.
# VITE_* variables are embedded in the client bundle — treat them as
# public but still manage them via environment variables, not hardcoded.
# All other variables are server-side only (Supabase Edge Functions).
# ============================================================

# ----------------------------------------------------------
# Supabase — Frontend (Vite / browser-side)
# ----------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Preferred client key name. Use the current sb_publishable_* key from
# Supabase Dashboard → Settings → API or Lovable Cloud → Backend → API keys.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Compatibility alias for older tooling that still expects the anon key name.
VITE_SUPABASE_ANON_KEY=

# ----------------------------------------------------------
# Supabase — Diagnostics / optional hardening
# ----------------------------------------------------------
VITE_DIAGNOSTICS_EXPECTED_URL=https://your-project-ref.supabase.co
VITE_DIAGNOSTICS_EXPECTED_PROJECT_ID=your-project-ref

# ----------------------------------------------------------
# Google client-side integrations
# ----------------------------------------------------------
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GOOGLE_ANALYTICS_ID=
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ----------------------------------------------------------
# Supabase Edge Functions / backend runtime
# ----------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------
# Transactional email (Resend)
# ----------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=info@peninsulaequine.systems
HQ_EMAIL_FROM=admin@notify.peninsulaequine.systems
BOOKINGS_EMAIL_FROM=bookings@notify.peninsulaequine.systems
QUOTES_EMAIL_FROM=quotes@notify.peninsulaequine.systems
NOREPLY_EMAIL_FROM=noreply@notify.peninsulaequine.systems
NOTIFICATION_EMAIL=info@peninsulaequine.systems

# ----------------------------------------------------------
# Internal secrets / integrations
# ----------------------------------------------------------
LOVABLE_API_KEY=your-lovable-api-key
GOOGLE_MAIL_API_KEY=your-lovable-gmail-connector-api-key
INTERNAL_FUNCTION_SECRET=generate-a-random-secret-here

# ----------------------------------------------------------
# Publish / diagnostics tooling
# ----------------------------------------------------------
SB_MGMT_ACCESS_TOKEN=your-supabase-management-token
SUPABASE_PROJECT_REF=your-project-ref
PUBLISH_LOG_INGEST_URL=
PUBLISH_LOG_INGEST_SECRET=generate-a-random-secret-here

# ----------------------------------------------------------
# Payments / optional external security connector
# ----------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
WIZ_API_URL=
WIZ_CLIENT_ID=
WIZ_CLIENT_SECRET=
WIZ_AUTH_URL=https://auth.app.wiz.io/oauth/token
WIZ_PROJECT_ID=

# ----------------------------------------------------------
# Optional end-to-end / smoke-test credentials (CI only)
# ----------------------------------------------------------
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
E2E_VERIFY_SECRET=generate-a-random-secret-here
E2E_BASE_URL=https://peninsulaequine.systems
MGMT_LINTS_ADMIN_JWT=
MGMT_LINTS_NON_ADMIN_JWT=

# VERCEL_URL is injected automatically by Vercel at deploy time.
