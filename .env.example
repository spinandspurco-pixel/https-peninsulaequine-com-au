# ============================================================
# Peninsula Equine — Environment Variables Reference
# ============================================================
# Copy this file to .env (never commit .env) and fill in real values.
# VITE_* variables are embedded in the client bundle — treat them as
# public but still manage them via environment variables, not hardcoded.
# All other variables are server-side only (Supabase Edge Functions).
# ============================================================

# ----------------------------------------------------------
# Supabase — Frontend (Vite / browser-side)
# ----------------------------------------------------------

# Your Supabase project URL  (e.g. https://<ref>.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable anon key — use the sb_publishable_* key.
# Obtain from Supabase Dashboard → Settings → API → Project API keys (anon/public key).
# If your project is managed through Lovable, you can also find it at:
#   Lovable Cloud → Project → Backend → API keys.
# Do NOT use the legacy eyJ… JWT format key; it will return 401s after key rotation.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Your Supabase project reference ID (the short code in the project URL)
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ----------------------------------------------------------
# Supabase — Diagnostics / optional hardening
# ----------------------------------------------------------

# Expected project URL — used by /hq diagnostics panel to detect mismatches
VITE_DIAGNOSTICS_EXPECTED_URL=https://your-project-ref.supabase.co

# Expected project ID — used by /hq diagnostics panel
VITE_DIAGNOSTICS_EXPECTED_PROJECT_ID=your-project-ref

# ----------------------------------------------------------
# Google Analytics
# ----------------------------------------------------------

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ----------------------------------------------------------
# Supabase — Edge Functions (server-side only)
# ----------------------------------------------------------

# Supabase project URL (same value as VITE_SUPABASE_URL, injected automatically
# by Supabase into Edge Functions — listed here for local supabase CLI use)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key (automatically injected by Supabase into Edge Functions)
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Supabase service role key — NEVER expose client-side.
# Used only in Edge Functions that require elevated DB access.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------
# Resend — Transactional email (Edge Functions only)
# ----------------------------------------------------------

# Resend API key — obtain from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Verified sending addresses on notify.peninsulaequine.systems
# Set whichever addresses your Resend domain verification covers.
HQ_EMAIL_FROM=admin@notify.peninsulaequine.systems
NOREPLY_EMAIL_FROM=noreply@notify.peninsulaequine.systems
BOOKINGS_EMAIL_FROM=bookings@notify.peninsulaequine.systems
QUOTES_EMAIL_FROM=quotes@notify.peninsulaequine.systems
FROM_EMAIL=info@peninsulaequine.systems

# Destination inbox for internal notifications
NOTIFICATION_EMAIL=info@peninsulaequine.systems

# ----------------------------------------------------------
# Internal function secrets (Edge Functions only)
# ----------------------------------------------------------

# Shared secret for internal Edge Function–to–Edge Function calls
INTERNAL_FUNCTION_SECRET=generate-a-random-secret-here

# Secret for the publish-log ingest endpoint
PUBLISH_LOG_INGEST_SECRET=generate-a-random-secret-here

# ----------------------------------------------------------
# Google APIs (Edge Functions only)
# ----------------------------------------------------------

# Google Mail (Gmail) connector API key — used by the Lovable connector gateway
# (connector-gateway.lovable.dev) to authenticate Gmail API calls via the
# Lovable Gmail connector. This is NOT a standard Google Cloud API key; obtain it
# from the Lovable platform connector settings.
GOOGLE_MAIL_API_KEY=your-lovable-gmail-connector-api-key

# ----------------------------------------------------------
# Lovable integration
# ----------------------------------------------------------

# Lovable API key — used by Edge Functions that interact with Lovable APIs
LOVABLE_API_KEY=your-lovable-api-key

# ----------------------------------------------------------
# Stripe (Edge Functions only)
# ----------------------------------------------------------

# Stripe secret key — NEVER expose client-side
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# End-to-end / CI testing (CI secrets only)
# ----------------------------------------------------------

# Shared secret for the /verify-admin-login edge function used in E2E tests
E2E_VERIFY_SECRET=generate-a-random-secret-here

# Test admin password used by E2E seed scripts
TEST_ADMIN_PASSWORD=test-admin-password

# JWT tokens for management-API lint checks (CI only)
MGMT_LINTS_ADMIN_JWT=your-admin-jwt
MGMT_LINTS_NON_ADMIN_JWT=your-non-admin-jwt
